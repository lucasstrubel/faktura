<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Modulansicht Kundenverwaltung (D-F-03 bis F-05). -->
<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="de.lucasstrubel.faktura.gui.KundenAnsichtController">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
    <top>
        <HBox spacing="8" alignment="CENTER_LEFT" BorderPane.alignment="CENTER_LEFT">
            <padding><Insets bottom="8"/></padding>
            <Label text="Suche:"/>
            <TextField fx:id="suchfeld" prefColumnCount="22"
                       promptText="Name oder Kundennummer…">
                <tooltip><Tooltip text="Suche nach Name oder Kundennummer"/></tooltip>
            </TextField>
        </HBox>
    </top>
    <center>
        <VBox spacing="4">
            <TableView fx:id="tabelle" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nummerSpalte" text="Kundennummer" prefWidth="130"/>
                    <TableColumn fx:id="nameSpalte" text="Name" prefWidth="260"/>
                    <TableColumn fx:id="strasseSpalte" text="Straße" prefWidth="220"/>
                    <TableColumn fx:id="plzSpalte" text="PLZ" prefWidth="80"/>
                    <TableColumn fx:id="ortSpalte" text="Ort" prefWidth="180"/>
                </columns>
            </TableView>
            <Label fx:id="trefferAnzeige" styleClass="treffer-anzeige"/>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <padding><Insets top="8"/></padding>
            <Button text="Neuen Kunden anlegen…" onAction="#legeNeuAn" defaultButton="true"/>
            <Button fx:id="bearbeitenKnopf" text="Bearbeiten…" onAction="#bearbeite"/>
            <Button fx:id="loeschenKnopf" text="Löschen" onAction="#loesche"/>
            <Button text="CSV exportieren…" onAction="#exportiere"/>
        </HBox>
    </bottom>
</BorderPane>
