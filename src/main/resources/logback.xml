<?xml version="1.0" encoding="UTF-8"?>
<!-- Konsole für Entwicklung, rollierende Datei im lokalen Datenverzeichnis (Q-06). -->
<configuration>

    <appender name="KONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Logverzeichnis folgt dem Datenverzeichnis; die installierte Anwendung
         setzt faktura.daten-verzeichnis als System-Property (jpackage). -->
    <property name="DATEN" value="${faktura.daten-verzeichnis:-daten}"/>

    <appender name="DATEI" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${DATEN}/faktura.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${DATEN}/faktura.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>14</maxHistory>
            <totalSizeCap>20MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="KONSOLE"/>
        <appender-ref ref="DATEI"/>
    </root>

</configuration>
